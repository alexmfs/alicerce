function gallery() {

	$("#thumblist a").first().addClass("active");

	$("#thumblist a").on('click', function (){
		var dataImg = $(this).attr("href");
		var datahref = $(this).attr("data-zoom");

		$("#thumblist a").removeClass("active");
		$(this).addClass("active");

		$(".galeria figure img").attr("src", dataImg);
		$(".galeria figure span img").attr("src", datahref);
		return false;
	});


	function galleryZoom(){

		if ($(window).width() > 800) {

			$( ".galeria figure" ).mousemove(function(e) {

				var largura = $(".galeria figure").width(),
					resetX = $(this).offset().left,
					resetY = $(this).offset().top,
					posX = (e.pageX - resetX) / largura * (-100)+'%',
					posY = (e.pageY - resetY) / largura * (-100)+'%';

				$('.galeria .zoom img').css({'left': posX , 'top': posY});
			});

		}
	}
	

}
gallery();



